"""Application settings."""

from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    model_config = SettingsConfigDict(env_file=".env", env_file_encoding="utf-8")

    app_name: str = "{{ project_name }}"
    environment: str = "local"
{% if "authx" in enabled_integrations %}
    jwt_secret_key: str = "change-me"
    jwt_access_token_expires: int = 900
{% endif %}
{% if "stripe" in enabled_integrations %}
    stripe_secret_key: str = ""
    stripe_webhook_secret: str = ""
{% endif %}
{% if "postgres" in enabled_integrations %}
    database_url: str = "postgresql+asyncpg://postgres:postgres@localhost:5432/{{ package_name }}"
{% endif %}
{% if "redis" in enabled_integrations %}
    redis_url: str = "redis://localhost:6379/0"
{% endif %}
{% for field in settings_fields %}
    {{ field }}
{% endfor %}


@lru_cache
def get_settings() -> Settings:
    return Settings()


settings = get_settings()
